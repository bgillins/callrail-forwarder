# OpenAI — used for Whisper transcription + GPT-4o-mini summarization
OPENAI_API_KEY=sk-...

# TextBelt — SMS delivery
TEXTBELT_API_KEY=your-textbelt-key

# Company configs — JSON array mapping CallRail companies to forwarding numbers
# Each company needs: companyId, label, forwardTo, signingKey, apiKey, accountId
COMPANY_CONFIG='[
  {
    "companyId": "COM...",
    "label": "Acme Dental",
    "forwardTo": "+17025551234",
    "signingKey": "your-callrail-webhook-signing-key",
    "apiKey": "your-callrail-api-key",
    "accountId": "227799611"
  }
]'
